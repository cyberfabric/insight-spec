apiVersion: v1
kind: Secret
metadata:
  name: clickhouse-credentials
  # Applied to both 'data' and 'argo' namespaces by apply.sh
  # (ClickHouse runs in 'data'; Argo workflows need it in 'argo' for dbt jobs)
  labels:
    app.kubernetes.io/part-of: insight
    app.kubernetes.io/component: clickhouse
type: Opaque
stringData:
  password: "CHANGE_ME"
